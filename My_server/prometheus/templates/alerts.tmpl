{{ range .Alerts.Resolved }}
{{ .Annotations.summary }}
{{ end }}
{{ end }}
{{ end }}

{{/* Webhook消息模板 */}}
{{ define "webhook.json" }}
{
  "alerts": {
    "firing": [
      {{ range $index, $alert := .Alerts.Firing }}
      {
        "status": "{{ $alert.Status }}",
        "labels": {
          {{ range $label := $alert.Labels }}
          "{{ $label.Name }}": "{{ $label.Value }}"{{ if not (last $index $alert.Labels) }},{{ end }}
          {{ end }}
        },
        "annotations": {
          {{ range $annotation := $alert.Annotations }}
          "{{ $annotation.Name }}": "{{ $annotation.Value }}"{{ if not (last $index $alert.Annotations) }},{{ end }}
          {{ end }}
        },
        "value": "{{ $alert.Value }}",
        "startsAt": "{{ $alert.StartsAt }}"
      }{{ if not (last $index $.Alerts.Firing) }},{{ end }}
      {{ end }}
    ],
    "resolved": [
      {{ range $index, $alert := .Alerts.Resolved }}
      {
        "status": "{{ $alert.Status }}",
        "labels": {
          {{ range $label := $alert.Labels }}
          "{{ $label.Name }}": "{{ $label.Value }}"{{ if not (last $index $alert.Labels) }},{{ end }}
          {{ end }}
        },
        "annotations": {
          {{ range $annotation := $alert.Annotations }}
          "{{ $annotation.Name }}": "{{ $annotation.Value }}"{{ if not (last $index $alert.Annotations) }},{{ end }}
          {{ end }}
        },
        "value": "{{ $alert.Value }}",
        "startsAt": "{{ $alert.StartsAt }}",
        "endsAt": "{{ $alert.EndsAt }}"
      }{{ if not (last $index $.Alerts.Resolved) }},{{ end }}
      {{ end }}
    ]
  },
  "commonLabels": {
    {{ range $label := .CommonLabels }}
    "{{ $label.Name }}": "{{ $label.Value }}"{{ if not (last $index $.CommonLabels) }},{{ end }}
    {{ end }}
  },
  "groupLabels": {
    {{ range $label := .GroupLabels }}
    "{{ $label.Name }}": "{{ $label.Value }}"{{ if not (last $index $.GroupLabels) }},{{ end }}
    {{ end }}
  },
  "status": "{{ .Status }}",
  "externalURL": "{{ .ExternalURL }}",
  "version": "{{ .Version }}"
}
{{ end }}

