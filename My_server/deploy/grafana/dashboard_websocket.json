{
  "dashboard": {
    "title": "CarpTMS WebSocket Monitoring",
    "tags": ["carptms", "websocket", "realtime"],
    "timezone": "browser",
    "panels": [
      {
        "title": "WebSocket Active Connections",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
        "targets": [{
          "expr": "websocket_connections",
          "legendFormat": "Active Connections"
        }],
        "thresholds": [
          {"color": "green", "value": null, "op": "lt"},
          {"color": "orange", "value": 500},
          {"color": "red", "value": 1000}
        ]
      },
      {
        "title": "Heartbeat Success Rate",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 3},
        "targets": [{
          "expr": "avg(websocket_connection_quality) * 100"
        }],
        "unit": "percent",
        "thresholds": [
          {"color": "red", "value": 95},
          {"color": "orange", "value": 98},
          {"color": "green", "value": 99.5}
        ]
      },
      {
        "title": "Reconnect Rate (per second)",
        "type": "stat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 3},
        "targets": [{
          "expr": "rate(websocket_reconnect_attempts_total[5m])"
        }],
        "thresholds": [
          {"color": "green", "value": 0.01},
          {"color": "orange", "value": 0.1},
          {"color": "red", "value": 0.5}
        ]
      },
      {
        "title": "Average RTT (ms)",
        "type": "stat",
        "gridPos": {"x": 12, "y": 3, "w": 6, "h": 3},
        "targets": [{
          "expr": "histogram_quantile(0.5, websocket_heartbeat_rtt_bucket)"
        }],
        "unit": "ms",
        "thresholds": [
          {"color": "green", "value": 50},
          {"color": "orange", "value": 200},
          {"color": "red", "value": 1000}
        ]
      },
      {
        "title": "Message Queue Length",
        "type": "stat",
        "gridPos": {"x": 18, "y": 3, "w": 6, "h": 3},
        "targets": [{
          "expr": "websocket_message_queue_length"
        }],
        "thresholds": [
          {"color": "green", "value": 10},
          {"color": "orange", "value": 50},
          {"color": "red", "value": 100}
        ]
      },
      {
        "title": "Heartbeat Success Rate Trend",
        "type": "graph",
        "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(websocket_heartbeat_total[5m])",
            "legendFormat": "Total Heartbeats/s"
          },
          {
            "expr": "rate(websocket_heartbeat_failures_total[5m])",
            "legendFormat": "Failed Heartbeats/s"
          }
        ]
      },
      {
        "title": "Connection Events",
        "type": "graph",
        "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(websocket_connections_total[5m])",
            "legendFormat": "New Connections/s"
          },
          {
            "expr": "rate(websocket_disconnections_total[5m])",
            "legendFormat": "Disconnections/s"
          }
        ]
      },
      {
        "title": "Messages Throughput",
        "type": "graph",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(websocket_messages_sent_total[5m])",
            "legendFormat": "Sent/s"
          },
          {
            "expr": "rate(websocket_messages_received_total[5m])",
            "legendFormat": "Received/s"
          }
        ]
      },
      {
        "title": "Connection Quality Gauge",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 12, "w": 6, "h": 6},
        "targets": [{
          "expr": "avg(websocket_connection_quality) * 100"
        }],
        "unit": "percent",
        "min": 0,
        "max": 100,
        "thresholds": [
          {"color": "red", "value": 0},
          {"color": "orange", "value": 95},
          {"color": "green", "value": 99}
        ]
      },
      {
        "title": "Alert Summary",
        "type": "alertlist",
        "gridPos": {"x": 18, "y": 12, "w": 6, "h": 6},
        "options": {
          "show": "current"
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
