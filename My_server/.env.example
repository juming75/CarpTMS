# CarpTMS 环境变量配置模板
# 
# 使用方式：
# 1. 复制此文件为 .env
# 2. 填入实际值（不要提交 .env 到版本控制！）
# 3. 在 Docker 部署时通过 -e 或 env_file 传入
#
# 敏感信息说明：
# - 所有以 SECRET、KEY、PASSWORD、PASSWORD 结尾的变量都是敏感信息
# - 生产环境务必使用强密码和安全的密钥

# ============ 数据库配置 ============
DATABASE_URL=postgres://carptms:your_secure_password@localhost:5432/carptms_db
DB_POOL_MIN=10
DB_POOL_MAX=300
DB_TIMEOUT=30

# ============ Redis 配置 ============
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_POOL_SIZE=16

# ============ JWT 安全配置 ============
# JWT 签名密钥（生产环境务必使用 64+ 字符的随机字符串）
JWT_SECRET=your_very_long_and_secure_secret_key_at_least_64_characters_for_production
JWT_EXPIRATION_HOURS=24
# JWT 刷新令牌密钥
JWT_REFRESH_SECRET=your_very_long_and_secure_refresh_secret_key_at_least_64_characters

# ============ API 密钥配置 ============
# API 认证密钥（用于内部服务间调用）
API_INTERNAL_KEY=your_internal_api_key_here
# 第三方 API 密钥（如天气、地图等）
EXTERNAL_API_KEYS__MAP_BOX=your_mapbox_api_key
EXTERNAL_API_KEYS__WEATHER=your_weather_api_key

# ============ 加密配置 ============
# 数据加密密钥（AES-256）
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
# 用于密码哈希的盐值
PASSWORD_SALT_ROUNDS=12

# ============ 文件上传配置 ============
# 文件上传密钥
UPLOAD_SECRET_KEY=your_upload_secret_key
# 最大文件大小（字节）
MAX_UPLOAD_SIZE=10485760

# ============ OpenTelemetry 配置 ============
# 链路追踪端点
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=carptms-server
OTEL_TRACING_ENABLED=true

# ============ 外部服务配置 ============
# AI 服务配置
AI_API_KEY=your_ai_service_api_key
AI_BASE_URL=https://api.example.com

# ============ 日志配置 ============
RUST_LOG=info
RUST_BACKTRACE=1

# ============ 终端设备配置 ============
# 终端认证密钥
TERMINAL_AUTH_KEY=your_terminal_authentication_key
# 终端 API 密钥
TERMINAL_API_KEY=your_terminal_api_key

# ============ WebSocket 配置 ============
# WebSocket 认证密钥
WEBSOCKET_SECRET=your_websocket_secret_key

# ============ 备份配置 ============
# 数据库备份加密密钥
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key

# ============ 生产环境覆盖 ============
# 设置为 true 启用生产模式
PRODUCTION_MODE=false
