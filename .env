# CarpTMS 环境变量配置
# 
# 使用方式：
# 1. 复制此文件为 .env (如果需要自定义)
# 2. 填入实际值（生产环境务必使用安全的密钥管理！）
#
# 🔒 敏感信息注意：
# - 此文件仅包含示例占位符，无真实敏感信息
# - 生产环境请使用环境变量或密钥管理服务注入
# - 不要将真实密钥提交到版本控制！

# ============ 数据库配置 ============
DATABASE_URL=postgres://postgres:123@localhost:5432/CarpTMS_db
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_TIMEOUT=30

# ============ Redis 配置 ============
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=16

# ============ JWT 安全配置 ============
# ⚠️ 生产环境务必使用至少64字符的随机密钥！
# 生成命令: openssl rand -hex 64
JWT_SECRET=dev_jwt_secret_change_in_production_1234567890123456789012345678901234567890
JWT_EXPIRATION_HOURS=24

# ============ 加密配置 ============
# ⚠️ 生产环境务必使用安全的加密密钥！
ENCRYPTION_KEY=dev_encryption_key_change_in_production_00000000000000000000000000000000

# ============ 日志配置 ============
RUST_LOG=info
RUST_BACKTRACE=1

# ============ 服务配置 ============
SERVER_PORT=8082

# ============ AI 模型配置（可选）========
AI_ENABLED=false
AI_MODEL_PATH=./models/Qwen3.5-9B-Q4_K_M.gguf
