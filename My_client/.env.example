# CarpTMS 环境变量配置示例
# 复制此文件为 .env.local 或 .env 并填入实际值
# 注意: .env.local 不会提交到 Git

# ============ API 配置 ============
VITE_API_BASE_URL=http://localhost:8082
VITE_WS_URL=ws://localhost:8082/ws

# ============ 地图 API 密钥 ============
# 天地图 API 密钥
# 申请地址: https://console.tianditu.gov.cn/
VITE_TIANDITU_KEY=your_tianditu_api_key_here

# 高德地图 API 密钥 (可选)
VITE_AMAP_KEY=your_amap_api_key_here

# ============ 功能开关 ============
VITE_ENABLE_REMOTE_OPS=false

# ============ 应用配置 ============
VITE_APP_TITLE=CarpTMS
