*.rdb
*.aof

# Cargo.lock (对于开源项目，建议保留以确保可重现构建)
# 如果确实不需要，注释掉下一行
Cargo.lock

# 二进制文件
*.exe
*.dll
*.so
*.dylib

# 测试覆盖率
cov/
lcov.info
coverage.info

